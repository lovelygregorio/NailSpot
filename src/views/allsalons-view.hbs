{{> menu}}

<section class="section">
  <div class="container">
    <h1 class="title">Dublin Nail Salons</h1>
    <p class="subtitle">Demo salons and manually added salons</p>

    <div class="columns is-multiline">
      {{#each salons}}
        <div class="column is-half">
          <div class="box">
            <h3 class="title is-5">{{name}}</h3>
            <p><strong>Area:</strong> {{area}}</p>
            <p><strong>Address:</strong> {{address}}</p>
            <p><strong>Services:</strong> {{services}}</p>
            <p><strong>Rating:</strong> {{rating}} / 5</p>
            <p><strong>Notes:</strong> {{notes}}</p>

            <div class="mt-3 buttons">
              <a href="/salon/{{_id}}" class="button is-small is-link">View Details</a>
              <a href="/dashboard/deletesalon/{{_id}}" class="button is-small is-danger">Delete</a>
            </div>
          </div>
        </div>
      {{else}}
        <div class="column is-12">
          <div class="notification is-info">No salons saved yet.</div>
        </div>
      {{/each}}
    </div>
  </div>
</section>
