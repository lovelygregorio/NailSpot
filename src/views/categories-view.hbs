{{> menu}}

<section class="section">

  <div class="container">

    <h1 class="title">Nail Categories</h1>
    <p class="subtitle">Browse salons by service type in Dublin</p>

    <div class="columns is-multiline">
      {{#each categories}}
      <div class="column is-one-third">
        <div class="box has-text-centered">
          <a href="/categories/{{_id}}">
            <h3 class="title is-5">
              💅 {{title}}
            </h3>
            <p class="has-text-grey">
              ({{salonCount}} salons)
            </p>

          </a>

        </div>

      </div>
      {{/each}}
    </div>

  </div>

</section>