<!--
  Add Salon Form

  This form allows users to add a new nail salon.
  Data is submitted to the /dashboard/addsalon route.
-->
<div class="box pink-card">
  <h2 class="title is-4">Add Nail Salon</h2>

<!-- The form uses Bulma classes for styling and includes
 fields for all necessary salon information.
The category dropdown is dynamically populated using Handlebars to
 iterate over the categories passed from the server. -->

  <form action="/dashboard/addsalon" method="POST">
    <div class="field">
      <label class="label">Salon Name</label>
      <div class="control">
        <input class="input" type="text" name="name" placeholder="Tropical Nails" required>
      </div>
    </div>

<!-- The area field is a dropdown with predefined options for different regions of Dublin. -->
    <div class="field">
      <label class="label">Area</label>
      <div class="control">
        <div class="select is-fullwidth">
          <select name="area" required>
            <option value="">Select Area</option>
            <option>North Dublin</option>
            <option>South Dublin</option>
            <option>Central Dublin</option>
          </select>
        </div>
      </div>
    </div>

<!-- The category field is a dropdown that is dynamically 
populated with categories from the database.
Each category is rendered as an option with its unique identifier 
as the value and its title as the display text. -->

    <div class="field">
      <label class="label">Category</label>
      <div class="control">
        <div class="select is-fullwidth">
          <select name="categoryid" required>
            <option value="">Select Category</option>
            {{#each categories}}
              <option value="{{_id}}">{{title}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>

<!-- The address, services, rating, notes, latitude, and longitude fields are
 standard input fields for collecting the necessary information about the salon. --> 
    <div class="field">
      <label class="label">Address</label>
      <div class="control">
        <input class="input" type="text" name="address" placeholder="24 Henry St, Dublin 1" required>
      </div>
    </div>

    <div class="field">
      <label class="label">Services</label>
      <div class="control">
        <input class="input" type="text" name="services" placeholder="Gel, Acrylic" required>
      </div>
    </div>

    <div class="field">
      <label class="label">Rating</label>
      <div class="control">
        <input class="input" type="number" name="rating" min="1" max="5" value="4" required>
      </div>
    </div>

    <div class="field">
      <label class="label">Notes</label>
      <div class="control">
        <textarea class="textarea" name="notes" placeholder="Friendly staff"></textarea>
      </div>
    </div>

    <div class="field">
      <label class="label">Latitude</label>
      <div class="control">
        <input class="input" type="number" step="any" name="latitude" placeholder="53.3498" required>
      </div>
    </div>

    <div class="field">
      <label class="label">Longitude</label>
      <div class="control">
        <input class="input" type="number" step="any" name="longitude" placeholder="-6.2603" required>
      </div>
    </div>

    <div class="field">
      <div class="control">
        <button class="button is-link">Add Salon</button>
      </div>
    </div>
  </form>
</div>