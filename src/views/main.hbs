<!--
  Home / Landing Page

  Introduces the NailSpot Dublin application.
  Highlights features and encourages users to sign up or log in.
-->

{{> welcome-menu}}

<section class="hero is-medium hero-gradient">
  <div class="hero-body">
    <div class="container">
      <div class="columns is-vcentered">
        <div class="column is-7">
          <h1 class="title is-1">NailSpot Dublin</h1>
          <p class="subtitle is-4">A web application where users can save and explore nail salons in Dublin.</p>
          <p class="mb-5">Discover salons by area, save useful notes, compare services, and manage your favourite nail salon locations all in one place.</p>
          <div class="buttons">
            <a class="button is-dark" href="/signup">Create Account</a>
            <a class="button is-light" href="/login">Login</a>
          </div>
        </div>
        <div class="column is-5">
          <div class="box pink-card">
            <h2 class="title is-4">Perfect for</h2>
            <ul>
              <li>• Women looking for nail salons in Dublin</li>
              <li>• Tourists visiting the city</li>
              <li>• Students searching for affordable options</li>
              <li>• Users saving favourite nail salon POIs</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="columns is-multiline">
      <div class="column is-4"><div class="box pink-card"><h3 class="title is-5">1. Register or Login</h3><p>Create an account to manage your salon POIs.</p></div></div>
      <div class="column is-4"><div class="box pink-card"><h3 class="title is-5">2. Add Nail Salon</h3><p>Save salon name, area, address, services, rating, notes, and map location.</p></div></div>
      <div class="column is-4"><div class="box pink-card"><h3 class="title is-5">3. Explore Dublin</h3><p>View all salons on a dashboard with a Leaflet map.</p></div></div>
    </div>
  </div>
</section>
