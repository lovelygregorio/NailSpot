<!--
  Category Salons Page

  Displays all salons belonging to a selected category.
  Allows users to view individual salon details.
-->
{{> menu}}

<section class="section">

  <div class="container">

    <h1 class="title">💅 {{category.title}} Salons</h1>

    <div class="columns is-multiline">

      {{#each salons}}

      <div class="column is-one-third">

        <div class="box">

          <h3 class="title is-5">{{name}}</h3>

          <p><strong>Area:</strong> {{area}}</p>
          <p><strong>Address:</strong> {{address}}</p>
          <p><strong>Services:</strong> {{services}}</p>

          <a href="/salon/{{_id}}" class="button is-small is-primary mt-2">
            View Salon
          </a>

        </div>

      </div>

      {{/each}}

    </div>

  </div>

</section>